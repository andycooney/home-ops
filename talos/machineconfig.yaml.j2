version: v1alpha1
debug: false
persist: true
machine:
  kernel:
    modules:
      - name: thunderbolt
      - name: thunderbolt_net
  type: controlplane
  token: ref+op://kubernetes/talos/TRUSTDINFO_TOKEN
  ca:
    crt: ref+op://kubernetes/talos/CERTS_OS_CRT
    key: ref+op://kubernetes/talos/CERTS_OS_KEY
  certSANs:
    - 172.16.16.10
    - 172.16.16.11
    - 172.16.16.12
    - 172.16.16.13
    - talos.cooney.site
    - talos01.cooney.site
    - talos02.cooney.site
    - talos03.cooney.site
  kubelet:
    image: ghcr.io/siderolabs/kubelet:v1.36.2
    extraConfig:
      serializeImagePulls: false
    defaultRuntimeSeccompProfileEnabled: true
    nodeIP:
      validSubnets:
        - 172.16.16.0/24
    disableManifestsDirectory: true
  network:
    interfaces:
      - deviceSelector:
          driver: igc
        ignore: true
  install:
    diskSelector:
      model: "KINGSTON OM8TAP41024K1-A00"
    image: {{ "factory.talos.dev/metal-installer/" + ENV.TALOS_SCHEMATIC_ID + ":" + ENV.TALOS_VERSION }}
    wipe: false
    grubUseUKICmdline: true
  files:
    - content: |
        [plugins."io.containerd.cri.v1.images"]
          discard_unpacked_layers = false
        [plugins."io.containerd.cri.v1.runtime"]
          device_ownership_from_security_context = true
      permissions: 0o0
      path: /etc/cri/conf.d/20-customization.part
      op: create
  time:
    disabled: false
    servers:
      - 162.159.200.1
      - 162.159.200.123
  sysctls:
    net.ipv4.conf.enp87s0.forwarding: "0"
    net.ipv4.conf.enp89s0.forwarding: "0"
    net.ipv6.conf.enp87s0.forwarding: "0"
    net.ipv6.conf.enp89s0.forwarding: "0"
    fs.inotify.max_user_instances: "8192"
    fs.inotify.max_user_watches: "1048576"
    net.core.rmem_max: "7500000"
    net.core.wmem_max: "7500000"
    net.ipv4.neigh.default.gc_thresh1: "4096"
    net.ipv4.neigh.default.gc_thresh2: "8192"
    net.ipv4.neigh.default.gc_thresh3: "16384"
    net.ipv4.tcp_slow_start_after_idle: "0"
    user.max_user_namespaces: "11255"
  features:
    kubernetesTalosAPIAccess:
      enabled: true
      allowedRoles:
        - os:admin
      allowedKubernetesNamespaces:
        - system-upgrade
    diskQuotaSupport: true
    kubePrism:
      enabled: true
      port: 7445
    hostDNS:
      enabled: true
      forwardKubeDNSToHost: true
  nodeLabels:
    node.kubernetes.io/exclude-from-external-load-balancers: ""
cluster:
  id: ref+op://kubernetes/talos/CLUSTER_ID
  secret: ref+op://kubernetes/talos/CLUSTER_SECRET
  controlPlane:
    endpoint: https://172.16.16.10:6443
  clusterName: kubernetes
  network:
    cni:
      name: none
    dnsDomain: cluster.local
    podSubnets:
      - 172.16.20.0/22
    serviceSubnets:
      - 172.16.24.0/22
  token: ref+op://kubernetes/talos/SECRETS_BOOTSTRAPTOKEN
  secretboxEncryptionSecret: ref+op://kubernetes/talos/SECRETS_SECRETBOXENCRYPTIONSECRET
  ca:
    crt: ref+op://kubernetes/talos/CERTS_K8S_CRT
    key: ref+op://kubernetes/talos/CERTS_K8S_KEY
  aggregatorCA:
    crt: ref+op://kubernetes/talos/CERTS_K8SAGGREGATOR_CRT
    key: ref+op://kubernetes/talos/CERTS_K8SAGGREGATOR_KEY
  serviceAccount:
    key: ref+op://kubernetes/talos/CERTS_K8SSERVICEACCOUNT_KEY
  apiServer:
    image: registry.k8s.io/kube-apiserver:v1.36.2
    extraArgs:
      enable-aggregator-routing: "true"
      feature-gates: HPAScaleToZero=true
    certSANs:
      - 172.16.16.10
      - kubernetes.cooney.site
    auditPolicy:
      apiVersion: audit.k8s.io/v1
      kind: Policy
      rules:
        - level: Metadata
  controllerManager:
    image: registry.k8s.io/kube-controller-manager:v1.36.2
    extraArgs:
      bind-address: 0.0.0.0
      feature-gates: HPAScaleToZero=true
  proxy:
    disabled: true
    image: registry.k8s.io/kube-proxy:v1.36.2
  scheduler:
    image: registry.k8s.io/kube-scheduler:v1.36.2
    extraArgs:
      bind-address: 0.0.0.0
      feature-gates: HPAScaleToZero=true
  discovery:
    enabled: true
    registries:
      kubernetes:
        disabled: true
      service: {}
  etcd:
    ca:
      crt: ref+op://kubernetes/talos/CERTS_ETCD_CRT
      key: ref+op://kubernetes/talos/CERTS_ETCD_KEY
    extraArgs:
      listen-metrics-urls: http://0.0.0.0:2381
    advertisedSubnets:
      - 172.16.16.0/24
  coreDNS:
    disabled: true
  allowSchedulingOnControlPlanes: true
---
apiVersion: v1alpha1
kind: LinkAliasConfig
name: net0
selector:
  match: link.bus_path == "0000:02:00.0" && link.driver == "i40e"
---
apiVersion: v1alpha1
kind: BondConfig
name: bond0
links:
  - net0
bondMode: active-backup
mtu: 1500
---
apiVersion: v1alpha1
kind: Layer2VIPConfig
name: 172.16.16.10
link: bond0
---
apiVersion: v1alpha1
kind: DHCPv4Config
name: bond0
clientIdentifier: mac
---
apiVersion: v1alpha1
kind: VLANConfig
name: bond0.666
parent: bond0
vlanID: 666

---
apiVersion: v1alpha1
kind: LinkAliasConfig
name: ceph-tb0
selector:
  match: link.bus_path == "1-1.0" && link.driver == "thunderbolt-net"
---
apiVersion: v1alpha1
kind: LinkAliasConfig
name: ceph-tb1
selector:
  match: link.bus_path == "0-1.0" && link.driver == "thunderbolt-net"

