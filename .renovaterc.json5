{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "github>home-operations/renovate-presets#1.3.1",
    ":timezone(America/New_York)",
  ],
  packageRules: [
    // Auto-merge rules
    {
      description: "Auto-merge patch and digest updates after checks pass",
      matchUpdateTypes: ["patch", "digest"],
      automerge: true,
      automergeType: "pr",
      platformAutomerge: true,
      ignoreTests: false,
    },
    {
      description: "Auto-merge high-cadence OCI packages weekly",
      matchDatasources: ["docker"],
      matchUpdateTypes: ["minor", "patch"],
      matchPackageNames: ["/kube-prometheus-stack/"],
      automerge: true,
      automergeType: "pr",
      platformAutomerge: true,
      ignoreTests: false,
      schedule: ["before 6am on Monday"],
    },
    {
      description: "Auto-merge GitHub Actions patch and digest updates after checks pass",
      matchManagers: ["github-actions"],
      matchUpdateTypes: ["patch", "digest"],
      automerge: true,
      automergeType: "pr",
      platformAutomerge: true,
      minimumReleaseAge: "3 days",
      ignoreTests: false,
    },
    {
      description: "Auto-merge trusted GitHub Actions patch and digest updates after checks pass",
      matchManagers: ["github-actions"],
      matchPackageNames: ["/^actions\\//", "/^renovatebot\\//"],
      matchUpdateTypes: ["patch", "digest"],
      automerge: true,
      automergeType: "pr",
      platformAutomerge: true,
      minimumReleaseAge: "1 minute",
      ignoreTests: false,
    },
    {
      description: "Keep sensitive platform updates manual",
      matchPackageNames: [
        "/rook-ceph/",
        "/rook-ceph-cluster/",
        "/kube-prometheus-stack/",
        "/qdm12/gluetun/",
      ],
      automerge: false,
      ignoreTests: false,
    },
    {
      description: "Keep Grafana dashboard updates manual",
      matchDatasources: ["custom.grafana-dashboards"],
      matchUpdateTypes: ["major"],
      automerge: false,
      automergeType: "branch",
      ignoreTests: true,
    },
    {
      description: "Keep Renovate preset updates manual",
      matchManagers: ["renovate-config"],
      matchUpdateTypes: ["minor", "patch"],
      automerge: false,
      automergeType: "branch",
      ignoreTests: true,
    },
    // Grouping rules
    {
      description: "Actions Runner Controller Group",
      groupName: "actions-runner-controller",
      matchDatasources: ["docker"],
      matchPackageNames: ["/gha-runner-scale-set-controller/", "/gha-runner-scale-set/"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
      minimumGroupSize: 2,
    },
    {
      description: "Flux Operator Group",
      groupName: "flux-operator",
      matchDatasources: ["docker"],
      matchPackageNames: ["/flux-operator/", "/flux-instance/"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
      minimumGroupSize: 2,
    },
    {
      description: "Kubernetes Group",
      groupName: "kubernetes",
      matchDatasources: ["docker"],
      matchPackageNames: [
        "/kube-apiserver/",
        "/kube-controller-manager/",
        "/kube-proxy/",
        "/kube-scheduler/",
        "/kubelet/",
      ],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
      minimumGroupSize: 5,
    },
    {
      description: "Rook-Ceph Group",
      groupName: "rook-ceph",
      matchDatasources: ["docker"],
      matchPackageNames: ["/rook-ceph/", "/rook-ceph-cluster/"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
      minimumGroupSize: 2,
    },
    // Labeling rules
    {
      matchUpdateTypes: ["major"],
      addLabels: ["type/major"],
    },
    {
      matchUpdateTypes: ["minor"],
      addLabels: ["type/minor"],
    },
    {
      matchUpdateTypes: ["patch"],
      addLabels: ["type/patch"],
    },
    {
      matchUpdateTypes: ["digest"],
      addLabels: ["type/digest"],
    },
    {
      matchDatasources: ["docker"],
      addLabels: ["renovate/container"],
    },
    {
      matchDatasources: ["helm"],
      addLabels: ["renovate/helm"],
    },
    {
      matchManagers: ["github-actions"],
      addLabels: ["renovate/github-action"],
    },
    {
      matchDatasources: ["github-releases"],
      addLabels: ["renovate/github-release"],
    },
  ],
}